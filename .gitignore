# Python cache/build artifacts
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/
*.egg-info/
*.swp
*.swo

# Local virtual environments
.venv/
**/.venv/
venv/
**/venv/

# macOS
.DS_Store
**/.DS_Store

# Processor generated artifacts
processor/output/intermediate/
processor/data/*.sqlite
processor/data/*.db
processor/data/decoded/
processor/output/decoded/*
processor/output/accumulated/*
processor/output/pending_uploads/*
processor/output/reports.jsonl
processor/output/report_artifacts/
!processor/output/decoded/.gitkeep
!processor/output/accumulated/.gitkeep
!processor/output/pending_uploads/.gitkeep

# Local telemetry queues and processed inputs
processor/input/unprocessed/*
processor/input/processed/*
!processor/input/unprocessed/.gitkeep
!processor/input/processed/.gitkeep

# Local/debug telemetry data
processor/debug_tlm/

# Manual build artifacts
manual/*.aux
manual/*.log
manual/*.out

# Server local database/runtime
server/data/

# Local scratch experiments
scratch/
**/scratch/
